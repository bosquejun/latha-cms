{
  "name": "@latha/start",
  "version": "0.0.0",
  "description": "LathaCMS integration for TanStack Start — runtime, RPC dispatcher, client, and admin UI.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./routes/login": {
      "types": "./dist/routes/login.d.ts",
      "import": "./dist/routes/login.js"
    },
    "./routes/admin": {
      "types": "./dist/routes/admin.d.ts",
      "import": "./dist/routes/admin.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "dependencies": {
    "@tanstack/virtual-file-routes": "^1.162.0",
    "lucide-react": "^0.469.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@latha/admin-sdk": "workspace:*",
    "@latha/auth": "workspace:*",
    "@latha/content": "workspace:*",
    "@latha/core": "workspace:*",
    "@latha/ui": "workspace:*",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-start": "^1.168.0",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@latha/admin-sdk": "workspace:*",
    "@latha/auth": "workspace:*",
    "@latha/content": "workspace:*",
    "@latha/core": "workspace:*",
    "@latha/ui": "workspace:*",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-start": "^1.168.0",
    "@tanstack/virtual-file-routes": "^1.162.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
