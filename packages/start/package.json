{
  "name": "@kon10/start",
  "version": "0.0.0",
  "description": "Kon10 integration for TanStack Start — runtime, RPC dispatcher, client, and Studio UI.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "development": "./src/server.ts",
      "import": "./dist/server.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./virtual": {
      "types": "./virtual.d.ts"
    },
    "./routes/login": {
      "types": "./dist/routes/login.d.ts",
      "development": "./src/routes/login.tsx",
      "import": "./dist/routes/login.js"
    },
    "./routes/studio": {
      "types": "./dist/routes/studio.d.ts",
      "development": "./src/routes/studio.tsx",
      "import": "./dist/routes/studio.js"
    },
    "./routes/rpc": {
      "types": "./dist/routes/rpc.d.ts",
      "development": "./src/routes/rpc.ts",
      "import": "./dist/routes/rpc.js"
    },
    "./routes/modules": {
      "types": "./dist/routes/modules.d.ts",
      "development": "./src/routes/modules.ts",
      "import": "./dist/routes/modules.js"
    },
    "./routes/api": {
      "types": "./dist/routes/api.d.ts",
      "development": "./src/routes/api.ts",
      "import": "./dist/routes/api.js"
    },
    "./envelope": {
      "types": "./dist/envelope.d.ts",
      "development": "./src/envelope.ts",
      "import": "./dist/envelope.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "virtual.d.ts"
  ],
  "dependencies": {
    "@tanstack/virtual-file-routes": "^1.162.0",
    "lucide-animated": "^1.0.5",
    "lucide-react": "^0.469.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test 'dist/**/*.test.js'"
  },
  "peerDependencies": {
    "@kon10/studio-sdk": "workspace:*",
    "@kon10/auth": "workspace:*",
    "@kon10/content": "workspace:*",
    "@kon10/core": "workspace:*",
    "@kon10/ui": "workspace:*",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-start": "^1.168.0",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@kon10/studio-sdk": "workspace:*",
    "@kon10/auth": "workspace:*",
    "@kon10/cache": "workspace:*",
    "@kon10/content": "workspace:*",
    "@kon10/core": "workspace:*",
    "@kon10/ui": "workspace:*",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-start": "^1.168.0",
    "@tanstack/virtual-file-routes": "^1.162.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
