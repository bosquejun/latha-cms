{
  "name": "create-kon10-app",
  "version": "0.1.0",
  "description": "Scaffold a new Kon10 app — a config-driven headless CMS on TanStack Start.",
  "type": "module",
  "bin": {
    "create-kon10-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test 'dist/**/*.test.js'",
    "prepack": "node ./scripts/sync-template-versions.mjs"
  },
  "keywords": [
    "kon10",
    "cms",
    "headless-cms",
    "tanstack-start",
    "scaffold",
    "create"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosquejun/kon10.git",
    "directory": "packages/create-kon10-app"
  },
  "homepage": "https://github.com/bosquejun/kon10#readme",
  "bugs": "https://github.com/bosquejun/kon10/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
