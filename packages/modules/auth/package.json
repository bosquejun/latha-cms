{
  "name": "@kon10/auth",
  "version": "2.0.0",
  "description": "Kon10 auth — session-based authentication, password hashing, AuthModule, and Studio UI.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./studio": {
      "types": "./dist/studio/index.d.ts",
      "development": "./src/studio/index.ts",
      "import": "./dist/studio/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.studio.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.studio.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test $(find dist -name '*.test.js' -print)",
    "test:coverage": "tsc -p tsconfig.json && node --test --experimental-test-coverage $(find dist -name '*.test.js' -print)"
  },
  "peerDependencies": {
    "@kon10/core": "workspace:^",
    "@kon10/cache": "workspace:^",
    "@kon10/studio-sdk": "workspace:^",
    "@kon10/ui": "workspace:^",
    "react": "^18 || ^19",
    "lucide-react": "^1.24.0"
  },
  "peerDependenciesMeta": {
    "@kon10/studio-sdk": {
      "optional": true
    },
    "@kon10/ui": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kon10/core": "workspace:^",
    "@kon10/cache": "workspace:^",
    "@kon10/studio-sdk": "workspace:^",
    "@kon10/ui": "workspace:^",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "lucide-react": "^1.24.0",
    "typescript": "^5.7.2",
    "vite": "^7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosquejun/kon10.git",
    "directory": "packages/modules/auth"
  },
  "homepage": "https://github.com/bosquejun/kon10#readme",
  "bugs": "https://github.com/bosquejun/kon10/issues",
  "keywords": [
    "kon10",
    "cms",
    "headless-cms",
    "tanstack-start",
    "auth",
    "rbac",
    "session"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./studio": {
        "types": "./dist/studio/index.d.ts",
        "import": "./dist/studio/index.js"
      }
    }
  }
}
