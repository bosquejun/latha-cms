{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "composite": true
  },
  "references": [
    { "path": "../../core" },
    { "path": "../../admin-sdk" }
  ],
  "include": [
    "src/admin/**/*.ts",
    "src/admin/**/*.tsx",
    "src/api-keys/token.ts",
    "src/crypto.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
