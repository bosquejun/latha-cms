{
  "name": "@latha/storage",
  "version": "0.0.0",
  "description": "LathaCMS storage — Drizzle/libsql DBAdapter (Turso default).",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
