{
  "name": "@latha/admin-sdk",
  "version": "0.0.0",
  "description": "LathaCMS admin SDK — CMS-aware shell, field renderers, and auto-generated views.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lexical/history": "^0.46.0",
    "@lexical/link": "^0.46.0",
    "@lexical/list": "^0.46.0",
    "@lexical/react": "^0.46.0",
    "@lexical/rich-text": "^0.46.0",
    "@lexical/selection": "^0.46.0",
    "@lexical/utils": "^0.46.0",
    "@tanstack/react-form": "^1.0.0",
    "lexical": "^0.46.0",
    "lucide-animated": "^1.0.5",
    "lucide-react": "^0.469.0"
  },
  "peerDependencies": {
    "@latha/core": "workspace:*",
    "@latha/ui": "workspace:*",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@latha/core": "workspace:*",
    "@latha/ui": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.2"
  }
