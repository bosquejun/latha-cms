{
  "name": "@kon10/studio-sdk",
  "version": "2.0.0",
  "description": "Kon10 Studio SDK — CMS-aware shell, field renderers, and auto-generated views.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test $(find dist -name '*.test.js' -print)",
    "test:coverage": "tsc -p tsconfig.json && node --test --experimental-test-coverage $(find dist -name '*.test.js' -print)"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@lexical/history": "^0.47.0",
    "@lexical/link": "^0.47.0",
    "@lexical/list": "^0.47.0",
    "@lexical/react": "^0.47.0",
    "@lexical/rich-text": "^0.47.0",
    "@lexical/selection": "^0.47.0",
    "@lexical/utils": "^0.47.0",
    "lexical": "^0.47.0",
    "lucide-animated": "^1.0.5",
    "lucide-react": "^1.24.0",
    "react-hook-form": "^7.81.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@kon10/core": "workspace:^",
    "@kon10/ui": "workspace:^",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@kon10/core": "workspace:^",
    "@kon10/ui": "workspace:^",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosquejun/kon10.git",
    "directory": "packages/studio-sdk"
  },
  "homepage": "https://github.com/bosquejun/kon10#readme",
  "bugs": "https://github.com/bosquejun/kon10/issues",
  "keywords": [
    "kon10",
    "cms",
    "headless-cms",
    "tanstack-start",
    "admin",
    "studio",
    "react"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
