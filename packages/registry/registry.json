{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "kon10",
  "homepage": "https://github.com/bosquejun/kon10",
  "items": [
    {
      "framework": "tanstack",
      "name": "kon10-client",
      "type": "registry:lib",
      "title": "Kon10 delivery client",
      "description": "A configured @kon10/client instance for reading content from a Kon10 Studio's delivery API.",
      "author": "Kon10",
      "dependencies": ["@kon10/client"],
      "files": [
        {
          "path": "tanstack/lib/kon10.ts",
          "type": "registry:lib",
          "target": "src/lib/kon10.ts"
        }
      ]
    },
    {
      "framework": "tanstack",
      "name": "blog",
      "type": "registry:block",
      "title": "Blog",
      "description": "A blog index and post pages for TanStack Start, reading a published `posts` collection from your Kon10 Studio's delivery API.",
      "author": "Kon10",
      "dependencies": ["@kon10/client", "zod"],
      "categories": ["blog", "content"],
      "files": [
        {
          "path": "tanstack/lib/kon10.ts",
          "type": "registry:lib",
          "target": "src/lib/kon10.ts"
        },
        {
          "path": "tanstack/blog/lib/posts.ts",
          "type": "registry:lib",
          "target": "src/lib/posts.ts"
        },
        {
          "path": "tanstack/blog/components/post-card.tsx",
          "type": "registry:component",
          "target": "src/components/blog/post-card.tsx"
        },
        {
          "path": "tanstack/blog/routes/index.tsx",
          "type": "registry:page",
          "target": "src/routes/blog/index.tsx"
        },
        {
          "path": "tanstack/blog/routes/$slug.tsx",
          "type": "registry:page",
          "target": "src/routes/blog/$slug.tsx"
        }
      ]
    }
  ]
}
