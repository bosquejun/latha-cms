{
  "name": "@kon10/registry",
  "version": "0.0.0",
  "private": true,
  "description": "Kon10 shadcn registry — builds the distributable registry-item JSON for the content-site templates.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && node dist/build.js",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test $(find dist -name '*.test.js' -print)"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
