{
  "name": "@kon10/client-react",
  "version": "2.0.0",
  "description": "React hooks for the Kon10 headless delivery client.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test $(find dist -name '*.test.js' -print)",
    "test:coverage": "tsc -p tsconfig.json && node --test --experimental-test-coverage $(find dist -name '*.test.js' -print)"
  },
  "dependencies": {
    "@kon10/client": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@kon10/client": "workspace:^",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bosquejun/kon10.git",
    "directory": "packages/clients/client-react"
  },
  "homepage": "https://github.com/bosquejun/kon10#readme",
  "bugs": "https://github.com/bosquejun/kon10/issues",
  "keywords": [
    "kon10",
    "cms",
    "headless-cms",
    "delivery-api",
    "client",
    "react",
    "hooks"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
