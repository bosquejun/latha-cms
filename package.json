{
  "name": "kon10cms",
  "version": "0.0.0",
  "private": true,
  "description": "A config-driven, modular headless CMS built on TanStack Start.",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "changeset:guard": "node scripts/check-no-major-changeset.mjs",
    "sourcemaps:upload": "node scripts/upload-sourcemaps.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@sentry/cli": "^2.58.6",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild"
    ],
    "packageExtensions": {
      "@hookform/resolvers": {
        "peerDependencies": {
          "zod": "*"
        }
      }
    }
  }
}
