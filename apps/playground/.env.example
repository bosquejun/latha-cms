# Kon10 playground environment.
#
#   cp .env.example .env
#
# Every var below has a working default, so an unedited copy runs the
# playground as-is: a local SQLite file, local-disk media, in-memory cache.
# Uncomment only what you want to override.

# ---------------------------------------------------------------------------
# Shared — read by both entrypoints (kon10.config.base.ts)
# ---------------------------------------------------------------------------

# HMAC secret for session cookies. The dev fallback below is what the code
# uses when this is unset. REQUIRED in production — @kon10/start throws on
# boot without it when NODE_ENV=production. Generate a real one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_SECRET=kon10-dev-secret-change-me

# First-run seed credentials. Only read when the users table is empty, so
# changing these after first boot does nothing — delete local.db to re-seed.
# ADMIN_EMAIL=admin@kon10.dev
# ADMIN_PASSWORD=password

# ---------------------------------------------------------------------------
# Local dev — kon10.config.ts (used whenever VERCEL is unset)
# ---------------------------------------------------------------------------

# Turso/libSQL connection. The `file:` default needs no running database.
# Point at a remote Turso instance with libsql://<name>-<org>.turso.io and
# set the auth token below.
# TURSO_DATABASE_URL=file:local.db
# TURSO_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Vercel — kon10.config.vercel.ts
#
# vite.config.ts selects this entrypoint only when VERCEL is set, which Vercel
# sets for you. These do nothing locally; set them in the Vercel dashboard.
# They have no safe defaults — the ones marked REQUIRED fail at connect time
# if missing, not at config parse time.
# ---------------------------------------------------------------------------

# REQUIRED. Postgres connection string. On Supabase use the *pooled* string —
# the adapter sets prepare: false for pgBouncer's transaction mode.
# DATABASE_URL=postgres://user:pass@host:5432/db

# S3-compatible media storage — Cloudflare R2, Supabase Storage, AWS S3, etc.
# S3_BUCKET=                 # REQUIRED
# S3_ACCESS_KEY_ID=          # REQUIRED
# S3_SECRET_ACCESS_KEY=      # REQUIRED
# S3_REGION=auto             # optional, defaults to `auto`
# S3_ENDPOINT=               # optional; needed for R2/Supabase, omit for AWS
# S3_PUBLIC_URL=             # optional; public base URL for stored objects

# Shared delivery-API cache. Defaults to redis://localhost:6379, which won't
# resolve on Vercel — treat this as required there.
# REDIS_URL=redis://localhost:6379
